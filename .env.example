# ===========================================
# ResumeRocket Frontend — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# Backend API URL
NEXT_PUBLIC_USER_API=http://localhost:8010

# Frontend base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# S3 bucket proxy URL (for resume file access)
NEXT_PUBLIC_BUCKET_PROXY_URL=

# Razorpay payment gateway (public key — for Indian users)
NEXT_PUBLIC_RAZORPAY_KEY=

# Stripe payment gateway (public key — for global users)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sentry error tracking
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Google Analytics
NEXT_PUBLIC_GA_ID=

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
# Optional: defaults to https://us.i.posthog.com — set to https://eu.i.posthog.com for EU residency
NEXT_PUBLIC_POSTHOG_HOST=

# Landing page rollback flag — set to "v1" to fall back to a static "we're updating" page
NEXT_PUBLIC_LANDING_VARIANT=

# Deployment mode (PRODUCTION or leave empty for development)
NEXT_PUBLIC_MODE=

# Service base URL (used in production)
NEXT_PUBLIC_SERVICE_BASE_URL=

# Server-only (NOT exposed to browser)
API_TOKEN=
GOOGLE_CHROME_PATH=
